   1          #include <REGX52.H>
   2          #include "Delay.h"
   3          
   4          //定义播放引脚
   5          sbit Buzzer = P2^5;
   6          
   7          /**
   8            * @brief  获取独立按键键码
   9            * @retval 按下按键的键码，范围：0~4，无按键按下时返回值为0
  10            */
  11          unsigned char Key()
  12          {
  13   1              unsigned char KeyNumber = 0;
  14   1              
  15   1              // 只要有按键按下，第一时间关闭定时器，停止发声！
  16   1              if(P3_1==0 || P3_0==0 || P3_2==0 || P3_3==0)
  17   1              {
  18   2                      TR0 = 0;     // 关闭定时器0
  19   2                      Buzzer = 1;  // 将蜂鸣器引脚拉高，防止杂音
  20   2                      
  21   2                      // 接着进行常规的消抖和松开检测
  22   2                      Delay(20);
  23   2                      if(P3_1==0){while(P3_1==0); Delay(20); KeyNumber=1;} // 上一首
  24   2                      else if(P3_0==0){while(P3_0==0); Delay(20); KeyNumber=2;} // 下一首
  25   2                      else if(P3_2==0){while(P3_2==0); Delay(20); KeyNumber=3;} 
  26   2                      else if(P3_3==0){while(P3_3==0); Delay(20); KeyNumber=4;} // 播放/暂停
  27   2              }
  28   1              
  29   1              return KeyNumber;
  30   1      }


